{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",

  "crons": [
    {
      "path": "/api/cron/sync-playas",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/ping-google",
      "schedule": "0 6 * * *"
    }
  ],

  "env": {
    "NEXT_PUBLIC_BASE_URL": "https://playas-espana.com"
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://playas-espana.com" }
      ]
    }
  ]
}
