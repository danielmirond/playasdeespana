# ─────────────────────────────────────────────
# PLAYAS DE ESPAÑA — Variables de entorno
# Copiar como .env.local y rellenar los valores
# NUNCA commitear .env.local al repositorio
# ─────────────────────────────────────────────

# URL base del sitio (sin trailing slash)
NEXT_PUBLIC_BASE_URL=https://playasdeespana.es

# AEMET OpenData — registro gratuito en:
# https://opendata.aemet.es/centrodedescargas/altaUsuario
AEMET_API_KEY=

# Google Places API — opcional, si no se define usa Overpass (OSM)
# Activar "Places API" en Google Cloud Console
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_KEY=

# Google Search Console — verificación de propiedad
# Se obtiene tras añadir el sitio en Search Console
GOOGLE_SITE_VERIFICATION=

# ─── Solo para Vercel (KV si lo usas para caché) ───
# VERCEL_KV_URL=
# VERCEL_KV_REST_API_URL=
# VERCEL_KV_REST_API_TOKEN=
